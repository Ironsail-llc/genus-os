# Genus OS instance environment — copy to /etc/robothor/robothor.env
# All systemd services source this file.

# Workspace root — where brain/, docs/agents/, memory/ live
ROBOTHOR_WORKSPACE=/home/robothor/robothor

# System user (must match User= in service files)
HOME=/home/robothor
PATH=/home/robothor/.local/bin:/usr/local/bin:/usr/bin:/bin

# Database
ROBOTHOR_DB_USER=robothor
ROBOTHOR_DB_NAME=robothor_memory
ROBOTHOR_DB_HOST=/var/run/postgresql

# Instance identity
ROBOTHOR_OWNER_NAME=Owner
ROBOTHOR_OWNER_EMAIL=owner@example.com
ROBOTHOR_AI_NAME=Genus
ROBOTHOR_AI_EMAIL=ai@example.com
ROBOTHOR_AI_PHONE=
ROBOTHOR_AI_DOMAIN=
ROBOTHOR_TELEGRAM_BOT_NAME=
