    "privacy": {
      "name": "Privacy Policy",
      "port": 3002,
      "host": "0.0.0.0",
      "health": "/",
      "systemd_unit": "robothor-privacy.service",
      "tunnel_route": "privacy.${INSTANCE_DOMAIN}",
      "dependencies": []
    }
  }
}
