{
  "version": "1.0.0",
  "description": "Genus OS service manifest — single source of truth for all service endpoints",
  "services": {
    "bridge": {
      "name": "Bridge Service",
      "port": 9100,
      "host": "127.0.0.1",
      "health": "/health",
      "systemd_unit": "robothor-bridge.service",
      "tunnel_route": "bridge.${INSTANCE_DOMAIN}",
      "dependencies": ["postgres", "redis"]
    },
    "orchestrator": {
      "name": "RAG Orchestrator",
      "port": 9099,
      "host": "0.0.0.0",
      "health": "/health",
      "systemd_unit": "robothor-orchestrator.service",
      "tunnel_route": "orchestrator.${INSTANCE_DOMAIN}",
      "dependencies": ["postgres", "redis", "ollama"]
    },
    "vision": {
      "name": "Vision Service",
      "port": 8600,
      "host": "0.0.0.0",
      "health": "/health",
      "systemd_unit": "robothor-vision.service",
      "tunnel_route": "vision.${INSTANCE_DOMAIN}",
      "dependencies": ["mediamtx"]
    },
    "helm": {
      "name": "Helm Dashboard",
      "port": 3004,
      "host": "0.0.0.0",
      "health": "/api/health",
      "systemd_unit": "robothor-app.service",
      "tunnel_route": "app.${INSTANCE_DOMAIN}",
      "dependencies": ["bridge", "orchestrator"]
    },
    "ollama": {
      "name": "Ollama LLM Server",
      "port": 11434,
      "host": "127.0.0.1",
      "health": "/api/tags",
      "systemd_unit": null,
      "tunnel_route": null,
      "dependencies": []
    },
    "mediamtx": {
      "name": "MediaMTX RTSP/HLS",
      "port": 8554,
      "host": "127.0.0.1",
      "health": null,
      "extra_ports": { "hls": 8890 },
      "systemd_unit": "mediamtx-webcam.service",
      "tunnel_route": "cam.${INSTANCE_DOMAIN}",
      "dependencies": []
    },
    "redis": {
      "name": "Redis",
      "port": 6379,
      "host": "127.0.0.1",
      "health": null,
      "systemd_unit": "redis-server.service",
      "tunnel_route": null,
      "dependencies": []
    },
    "postgres": {
      "name": "PostgreSQL",
      "port": 5432,
      "host": "127.0.0.1",
      "health": null,
      "systemd_unit": "postgresql.service",
      "tunnel_route": null,
      "dependencies": []
    },
    "status": {
      "name": "Status Server",
      "port": 3000,
      "host": "0.0.0.0",
      "health": "/",
      "systemd_unit": "robothor-status.service",
      "tunnel_route": "${INSTANCE_DOMAIN}",
      "dependencies": []
    },
    "status_dashboard": {
      "name": "Status Dashboard",
      "port": 3001,
      "host": "0.0.0.0",
      "health": "/",
      "systemd_unit": "robothor-status-dashboard.service",
      "tunnel_route": "status.${INSTANCE_DOMAIN}",
      "dependencies": []
    },
    "voice": {
      "name": "Voice Server",
      "port": 8765,
      "host": "0.0.0.0",
      "health": null,
      "systemd_unit": "robothor-voice.service",
      "tunnel_route": "voice.${INSTANCE_DOMAIN}",
      "dependencies": []
    },
    "sms": {
      "name": "SMS Webhook",
      "port": 8766,
      "host": "0.0.0.0",
      "health": null,
      "systemd_unit": "robothor-sms.service",
      "tunnel_route": "sms.${INSTANCE_DOMAIN}",
      "dependencies": []
    },
    "searxng": {
      "name": "SearXNG Search",
      "port": 8888,
      "host": "127.0.0.1",
      "health": "/healthz",
      "systemd_unit": null,
      "tunnel_route": null,
      "dependencies": []
