    "uptime_kuma": {
      "name": "Uptime Kuma",
      "port": 3010,
      "host": "127.0.0.1",
      "health": "/api/status-page/heartbeat",
      "systemd_unit": null,
      "tunnel_route": "monitor.${INSTANCE_DOMAIN}",
      "dependencies": []
    },
    "kokoro_tts": {
      "name": "Kokoro TTS",
      "port": 8880,
      "host": "127.0.0.1",
      "health": "/v1/models",
      "systemd_unit": null,
      "tunnel_route": "tts.${INSTANCE_DOMAIN}",
      "dependencies": []
    },
    "ops_dashboard": {
      "name": "Ops Dashboard",
      "port": 3003,
      "host": "0.0.0.0",
      "health": "/",
      "systemd_unit": "robothor-dashboard.service",
      "tunnel_route": "ops.${INSTANCE_DOMAIN}",
      "dependencies": []
